# BAKAY ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.
# .env dosyası git'e EKLENMEZ (anahtarlar gizli kalır).

# --- LLM sağlayıcı: "ollama" (yerel GPU) veya "gemini" (API) ---
# Mevcut: yerel YTÜ COSMOS Turkish-Gemma 9B (Ollama). Gemini bölge engeli
# nedeniyle kullanılmıyor; sağlayıcı yine de pluggable olarak duruyor.
LLM_PROVIDER=ollama

# Ollama (yerel GPU) — YTÜ COSMOS Turkish-Gemma 9B
# HF: ytu-ce-cosmos/Turkish-Gemma-9b → Ollama'ya bir Modelfile ile ekleyin.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=turkish-gemma-9b   # Ollama'da kullandığınız yerel etiket

# Gemini (opsiyonel/yedek API) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Embedding modeli (sentence-transformers adı) ---
# Türkçe + çok dilli iyi başlangıç seçenekleri:
#   sentence-transformers/LaBSE
#   intfloat/multilingual-e5-large
EMBEDDING_MODEL=sentence-transformers/LaBSE

# --- Vektör deposu ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=ktmu_docs

# --- Retrieval ---
TOP_K=5

# --- Ajansal akış düğümleri ---
# Skor kapısı: en yüksek benzerlik bunun altındaysa "kapsam dışı" (bedava).
SCORE_THRESHOLD=0.30
# LLM-ağırlıklı düğümler (her biri latency ekler). true/false.
AGENT_ROUTE=false      # LLM ile kapsam yönlendirmesi
AGENT_REWRITE=false    # sorgu yeniden yazma (retrieval kalitesi)
AGENT_VERIFY=false     # üretilen yanıtın dayanak doğrulaması
