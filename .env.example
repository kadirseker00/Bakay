# BAKAY ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.
# .env dosyası git'e EKLENMEZ (anahtarlar gizli kalır).

# --- LLM sağlayıcı: "gemini" (API) veya "ollama" (yerel GPU) ---
LLM_PROVIDER=gemini

# Gemini (API ile başlangıç) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (yerel GPU'ya geçince) — önce: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Embedding modeli (sentence-transformers adı) ---
# Türkçe + çok dilli iyi başlangıç seçenekleri:
#   sentence-transformers/LaBSE
#   intfloat/multilingual-e5-large
EMBEDDING_MODEL=sentence-transformers/LaBSE

# --- Vektör deposu ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=ktmu_docs

# --- Retrieval ---
TOP_K=5
